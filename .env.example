# Used by backend/server.mjs (loaded from repo root .env.local or .env).
# Frontend Vite dev/preview (port 5932) proxies /api/* to http://localhost:8787.
SEMANTIC_SCHOLAR_API_KEY=

# Optional: only if the app calls https://api.semanticscholar.org directly from the
# browser (e.g. static production build). The value is exposed in client JS.
# VITE_SEMANTIC_SCHOLAR_API_KEY=

# Optional: override search URL entirely.
# VITE_SEMANTIC_SCHOLAR_API_URL=
